# =============================================================================
# AI Smart Inbox — Environment Variables
# =============================================================================
# Copy this file to `backend/.env` and fill in your values.
# Never commit .env files containing real secrets to version control.
#
# Required variables are marked  [REQUIRED]
# Optional integrations are marked [OPTIONAL]
# =============================================================================


# \u2500\u2500 Server \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

PORT=4001
NODE_ENV=development


# \u2500\u2500 Database [REQUIRED] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/ai-inbox

# MongoDB Atlas (cloud — recommended for production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-inbox


# \u2500\u2500 Authentication [REQUIRED] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Generate a long, random secret. In bash: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-long-random-string-before-deploying

# How long tokens stay valid (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d


# \u2500\u2500 AI Provider (at least one is recommended) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Option A — Groq (free, fast, recommended)
# Sign up at https://console.groq.com/ — no credit card required
# Free tier: 14,400 requests/day with llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile

# Option B — OpenAI (paid)
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo


# \u2500\u2500 CORS [OPTIONAL] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:5173 when unset.
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com


# \u2500\u2500 Twilio — SMS / WhatsApp [OPTIONAL] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Required only if you want to send SMS replies via Twilio.
# Sign up at https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# \u2500\u2500 WhatsApp Cloud API [OPTIONAL] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Meta Business account required.
# See https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=


# \u2500\u2500 Slack [OPTIONAL] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Bot token from your Slack app (starts with xoxb-).
# Required only for posting replies back to Slack channels.
SLACK_BOT_TOKEN=


# \u2500\u2500 n8n Automation [OPTIONAL] \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

# Base URL of your n8n instance — used to trigger outbound webhooks.
N8N_WEBHOOK_URL=http://localhost:5678/webhook
