# Server Configuration
PORT=4001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ai-inbox

# Authentication - IMPORTANT: Change this in production!
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# AI Configuration (Choose ONE option)
# ---------------------------------------------
# Option 1: Groq (FREE - Recommended)
# Get your FREE API key at: https://console.groq.com/
# Free tier: 14,400 requests/day, no credit card required
GROQ_API_KEY=your-groq-api-key-here
AI_MODEL=llama-3.3-70b-versatile

# Option 2: OpenAI (Paid)
# Uncomment if you prefer OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# n8n Configuration (Optional - for automation workflows)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Platform API Keys (Optional - only needed for direct integrations)
# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=

# Twilio (for SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
